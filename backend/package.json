{
  "name": "Node Footwear",
  "version": "1.0.0",
  "main": "app.js",
  "type": "module",
  "scripts": {
    "start": "tsx -r tsconfig-paths/register src/server.ts",
    "dev": "nodemon",
    "dev:fast": "ts-node-dev --respawn -r tsconfig-paths/register src/server.ts",
    "clean": "rimraf dist",
    "build:local": "npm run clean && npm run lint && tsc && tsc-alias",
    "build": "npm run clean && npm run generate && tsc && tsc-alias && npm run migrate:deploy",
    "format": "prettier --write .",
    "check": "prettier --check .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "migrate": "prisma migrate dev --name init && npm run generate",
    "migrate:deploy": "prisma migrate deploy",
    "generate": "prisma generate",
    "studio": "prisma studio",
    "seed": "tsx prisma/seed.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.18.0",
    "@types/winston": "^2.4.4",
    "nodemon": "^3.1.11",
    "prisma": "^7.5.0",
    "rimraf": "^6.0.1",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.47.0"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@types/cookie-parser": "^1.4.9",
    "@types/jsonwebtoken": "^9.0.10",
    "bcrypt": "^5.1.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.5.1",
    "handlebars": "^4.7.8",
    "jsonwebtoken": "^9.0.2",
    "module-alias": "^2.2.3",
    "multer": "^2.0.2",
    "pg": "^8.20.0",
    "winston": "^3.17.0",
    "zod": "^3.25.67"
  }
}
